{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-idol-agency.local/schemas/idol_enriched.schema.json",
  "title": "IdolEnrichment",
  "type": "object",
  "required": [
    "schemaVersion",
    "idolId",
    "promptVersion",
    "nameRomaji",
    "nameJp",
    "background",
    "physical",
    "portraitPromptPositive"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "enum": [1, 2] },
    "idolId": { "type": "string" },
    "promptVersion": { "type": "string" },
    "nameRomaji": {
      "type": "string",
      "minLength": 1,
      "description": "Full name in romaji (family given). Generated by LLM, unique across pack."
    },
    "nameJp": {
      "type": "string",
      "minLength": 1,
      "description": "Full name in Japanese characters."
    },
    "background": {
      "type": "object",
      "required": ["pt", "ja"],
      "properties": {
        "pt": { "type": "string", "minLength": 1 },
        "ja": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "physical": {
      "type": "object",
      "required": [
        "hairStyle",
        "hairColor",
        "eyeShape",
        "eyeColor",
        "skinTone"
      ],
      "properties": {
        "hairStyle": { "type": "string" },
        "hairColor": { "type": "string" },
        "eyeShape": { "type": "string" },
        "eyeColor": { "type": "string" },
        "skinTone": { "type": "string" },
        "accessories": { "type": "string" },
        "outfitNotes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "portraitPromptPositive": {
      "type": "string",
      "description": "Bloco único de prompt positivo (fonte de verdade do retrato)."
    },
    "portraitPromptNegative": {
      "type": "string",
      "description": "Opcional; se vazio, usa default do runner."
    }
  },
  "additionalProperties": false
}
